# 複製到你的 .env.local 並填入你的值
# cp .env.example .env.local

# ─── Payload CMS ────────────────────────────────────────────
PAYLOAD_SECRET=your_payload_secret_here_change_this

# ─── 資料庫 ──────────────────────────────────────────────────
# 本機開發: sqlite (預設，不需設定)
PAYLOAD_DATABASE_PROVIDER=sqlite

# Production (Vercel + Neon PostgreSQL):
# PAYLOAD_DATABASE_PROVIDER=postgres
# DATABASE_URL=your_database_url_here
# PAYLOAD_DATABASE_PUSH=true

# ─── Better Auth ─────────────────────────────────────────────
BETTER_AUTH_SECRET=your_better_auth_secret_here_change_this
BETTER_AUTH_URL=http://localhost:3000

# ─── Google OAuth (選填) ─────────────────────────────────────
# 不設定此項目，Google OAuth 按鈕不會顯示（不會崩潰）
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret

# ─── Email Provider ──────────────────────────────────────────
# none = 訂閱寫入 DB，不寄信，全站正常運作
# resend | kit | agentmail
EMAIL_PROVIDER=none
# RESEND_API_KEY=your_resend_api_key

# ─── 金流 Provider ───────────────────────────────────────────
# none = /checkout 顯示「即將開放」，全站正常運作
# lemonsqueezy | payuni
PAYMENT_PROVIDER=none
# LEMONSQUEEZY_API_KEY=your_lemonsqueezy_api_key
# LEMONSQUEEZY_STORE_ID=your_store_id
# LEMONSQUEEZY_WEBHOOK_SECRET=your_webhook_secret

# ─── Next.js ─────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000
